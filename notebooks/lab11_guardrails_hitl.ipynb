        "            print(f\"Why: {attack.get('why_it_works', 'N/A')}\")\n",
        "    else:\n",
        "        print(\"Could not parse JSON. Raw response:\")\n",
        "        print(text[:500])\n",
        "        ai_attacks = []\n",
